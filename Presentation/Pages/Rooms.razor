@page "/rooms"
@rendermode RenderMode.InteractiveServer
@using Hotel.Domain.Entities
@using Hotel.Application.Requests.Queries
@using Hotel.Application.Requests.Commands
@using MediatR
@using Microsoft.AspNetCore.Identity
@inject IMediator Mediator
@inject NavigationManager Nav
@inject UserManager<ApplicationUser> UserManager
@inject AuthenticationStateProvider AuthState

<PageTitle>Our Rooms — AurumStay</PageTitle>

<div class="rooms-page">
    <div class="rooms-hero">
        <span class="rooms-eyebrow">AurumStay Accommodation</span>
        <h1 class="rooms-title">Stay in quiet elegance</h1>
        <p class="rooms-subtitle">Hand-selected rooms designed around how you arrive, rest, and return.</p>
    </div>

    @if (!string.IsNullOrEmpty(bookingMessage))
    {
        <div class="booking-toast">@bookingMessage</div>
    }

    <div class="filter-panel">
        <div class="filter-type-chips">
            @foreach (var t in RoomTypes)
            {
                <button class="chip @(selectedType == t ? "chip-active" : "")" @onclick="() => SetType(t)">
                    @t
                </button>
            }
        </div>

        <div class="filter-controls">
            <div class="filter-search">
                <span class="filter-search-icon">&#x1F50D;</span>
                <input type="text" placeholder="Search rooms…"
                       value="@searchTerm"
                       @oninput="@(e => searchTerm = e.Value?.ToString() ?? "")" />
            </div>

            <select class="filter-select" @bind="capacityFilter">
                <option value="0">Any guests</option>
                <option value="1">1+ guest</option>
                <option value="2">2+ guests</option>
                <option value="3">3+ guests</option>
                <option value="4">4+ guests</option>
            </select>

            <select class="filter-select" @bind="priceFilter">
                <option value="">Any price</option>
                <option value="under-300">Under 300 RON</option>
                <option value="300-600">300 – 600 RON</option>
                <option value="600-900">600 – 900 RON</option>
                <option value="over-900">Over 900 RON</option>
            </select>

            <select class="filter-select" @bind="sortBy">
                <option value="default">Sort: recommended</option>
                <option value="price-asc">Price: low to high</option>
                <option value="price-desc">Price: high to low</option>
                <option value="capacity-desc">Largest first</option>
            </select>

            <label class="filter-toggle">
                <input type="checkbox" @bind="onlyAvailable" />
                <span>Available only</span>
            </label>

            @if (HasActiveFilters)
            {
                <button class="filter-clear" @onclick="ClearFilters">Clear filters</button>
            }
        </div>
    </div>

    @if (rooms is null)
    {
        <div class="loading-state">
            <div class="spinner-gold"></div>
            <p>Curating your stay…</p>
        </div>
    }
    else
    {
        var filtered = FilteredRooms;
        <div class="result-count">
            @filtered.Count of @rooms.Count @(rooms.Count == 1 ? "room" : "rooms")
        </div>

        @if (filtered.Count == 0)
        {
            <div class="empty-state">
                <div class="empty-icon">&#x1F6CF;</div>
                <h4>No rooms match your filters</h4>
                <p>Try widening the criteria or clearing filters.</p>
                <button class="btn-book" @onclick="ClearFilters">Clear filters</button>
            </div>
        }
        else
        {
            <div class="rooms-grid">
                @foreach (var room in filtered)
                {
                    <div class="room-card">
                        <div class="room-photo-wrapper">
                            <div class="room-photo-placeholder @GetPlaceholderClass(room.RoomType)">
                                <span class="placeholder-icon">&#x1F6CF;</span>
                                <span class="placeholder-type">@room.RoomType</span>
                                <span class="placeholder-brand">AurumStay</span>
                            </div>
                            @if (!string.IsNullOrEmpty(room.PhotoPath))
                            {
                                <img src="@room.PhotoPath"
                                     alt="Room @room.RoomNumber"
                                     class="room-photo"
                                     loading="lazy"
                                     onerror="this.style.display='none'" />
                            }

                            <span class="availability-badge @(room.IsAvailable ? "badge-available" : "badge-unavailable")">
                                @(room.IsAvailable ? "Available" : "Booked")
                            </span>
                        </div>

                        <div class="room-body">
                            <div class="room-header-row">
                                <span class="room-number">Room @room.RoomNumber</span>
                                <span class="room-type-tag">@room.RoomType</span>
                            </div>

                            @if (!string.IsNullOrEmpty(room.Description))
                            {
                                <p class="room-description">@room.Description</p>
                            }

                            <div class="room-meta">
                                <div class="meta-item">
                                    <span class="meta-icon">&#x1F465;</span>
                                    <span>@room.Capacity @(room.Capacity == 1 ? "guest" : "guests")</span>
                                </div>
                                <div class="meta-item">
                                    <span class="meta-icon">&#x2728;</span>
                                    <span>@room.RoomType</span>
                                </div>
                            </div>

                            <div class="room-footer">
                                <div class="room-price">
                                    <span class="price-amount">@room.PricePerNight.ToString("C0")</span>
                                    <span class="price-per">/ night</span>
                                </div>

                                <AuthorizeView>
                                    <Authorized>
                                        @if (room.IsAvailable)
                                        {
                                            <button class="btn-book" @onclick="() => BookRoom(room)" disabled="@(bookingRoomId == room.Id)">
                                                @(bookingRoomId == room.Id ? "Reserving…" : "Reserve")
                                            </button>
                                        }
                                        else
                                        {
                                            <button class="btn-book btn-book-disabled" disabled>Unavailable</button>
                                        }
                                    </Authorized>
                                    <NotAuthorized>
                                        <a class="btn-book" href="/login?returnUrl=/rooms">Reserve</a>
                                    </NotAuthorized>
                                </AuthorizeView>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    }
</div>

<style>
    .rooms-page {
        padding: 0 0 64px 0;
        color: #1C1812;
    }

    .rooms-hero {
        background: linear-gradient(135deg, #14110B 0%, #2A2010 100%);
        color: #F5EBC7;
        text-align: center;
        padding: 64px 24px 48px;
        margin: -24px -12px 32px;
        border-radius: 0 0 28px 28px;
        position: relative;
        overflow: hidden;
    }

    .rooms-hero::after {
        content: "";
        position: absolute;
        inset: 0;
        background: radial-gradient(circle at 70% 30%, rgba(217,185,95,0.18), transparent 60%);
        pointer-events: none;
    }

    .rooms-eyebrow {
        display: inline-block;
        font-size: 0.72rem;
        font-weight: 600;
        letter-spacing: 0.22em;
        text-transform: uppercase;
        color: #D9B95F;
        margin-bottom: 14px;
    }

    .rooms-title {
        font-family: Georgia, "Times New Roman", serif;
        font-size: 2.6rem;
        font-weight: 500;
        margin-bottom: 10px;
        letter-spacing: -0.5px;
        color: #F7F1E6;
    }

    .rooms-subtitle {
        font-size: 1.02rem;
        color: rgba(245,235,199,0.75);
        margin: 0 auto;
        max-width: 520px;
    }

    /* ── Filter panel ── */
    .filter-panel {
        background: #FFFFFF;
        border: 1px solid #E7DCC5;
        border-radius: 18px;
        padding: 20px 22px;
        margin-bottom: 26px;
        box-shadow: 0 4px 20px rgba(20,17,11,0.05);
    }

    .filter-type-chips {
        display: flex;
        gap: 8px;
        flex-wrap: wrap;
        padding-bottom: 16px;
        margin-bottom: 16px;
        border-bottom: 1px solid #E7DCC5;
    }

    .chip {
        background: transparent;
        border: 1px solid #E7DCC5;
        color: #6F6657;
        padding: 7px 18px;
        border-radius: 22px;
        font-size: 0.82rem;
        font-weight: 600;
        letter-spacing: 0.04em;
        cursor: pointer;
        transition: all 0.18s ease;
    }

    .chip:hover {
        border-color: #B8943D;
        color: #14110B;
    }

    .chip-active {
        background: #14110B;
        color: #F5EBC7;
        border-color: #14110B;
    }

    .filter-controls {
        display: flex;
        flex-wrap: wrap;
        gap: 12px;
        align-items: center;
    }

    .filter-search {
        position: relative;
        flex: 1 1 220px;
        min-width: 180px;
    }

    .filter-search-icon {
        position: absolute;
        left: 14px;
        top: 50%;
        transform: translateY(-50%);
        color: #9C8E72;
        font-size: 0.85rem;
        pointer-events: none;
    }

    .filter-search input {
        width: 100%;
        padding: 10px 14px 10px 38px;
        border: 1px solid #E7DCC5;
        border-radius: 22px;
        font-size: 0.88rem;
        background: #FFFDF8;
        color: #14110B;
        outline: none;
        transition: border-color 0.18s, box-shadow 0.18s;
        font-family: inherit;
    }

    .filter-search input:focus {
        border-color: #D9B95F;
        background: #FFFFFF;
        box-shadow: 0 0 0 3px rgba(217,185,95,0.18);
    }

    .filter-select {
        padding: 10px 14px;
        border: 1px solid #E7DCC5;
        border-radius: 22px;
        font-size: 0.85rem;
        background: #FFFDF8;
        color: #14110B;
        cursor: pointer;
        outline: none;
        font-family: inherit;
        transition: border-color 0.18s, box-shadow 0.18s;
    }

    .filter-select:focus {
        border-color: #D9B95F;
        box-shadow: 0 0 0 3px rgba(217,185,95,0.18);
    }

    .filter-toggle {
        display: flex;
        align-items: center;
        gap: 8px;
        font-size: 0.85rem;
        color: #6F6657;
        cursor: pointer;
        padding: 0 4px;
    }

    .filter-toggle input {
        width: 16px; height: 16px;
        accent-color: #B8943D;
        cursor: pointer;
    }

    .filter-clear {
        background: transparent;
        color: #B8943D;
        border: 1px solid #B8943D;
        padding: 9px 18px;
        border-radius: 22px;
        font-size: 0.78rem;
        font-weight: 600;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        cursor: pointer;
        transition: all 0.18s;
    }

    .filter-clear:hover {
        background: #B8943D;
        color: #F5EBC7;
    }

    .result-count {
        font-size: 0.82rem;
        color: #9C8E72;
        margin: 4px 4px 18px;
        letter-spacing: 0.06em;
        text-transform: uppercase;
    }

    .loading-state, .empty-state {
        text-align: center;
        padding: 80px 24px;
        color: #6F6657;
    }

    .empty-icon { font-size: 3rem; margin-bottom: 16px; }
    .empty-state h4 { color: #1C1812; font-family: Georgia, serif; font-weight: 500; }
    .empty-state .btn-book { margin-top: 20px; }

    .spinner-gold {
        width: 36px; height: 36px;
        border: 3px solid rgba(217,185,95,0.25);
        border-top-color: #D9B95F;
        border-radius: 50%;
        margin: 0 auto 18px;
        animation: spin 0.9s linear infinite;
    }

    @@keyframes spin { to { transform: rotate(360deg); } }

    .rooms-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(310px, 1fr));
        gap: 28px;
        padding: 0 8px;
    }

    .room-card {
        background: #FFFFFF;
        border-radius: 18px;
        overflow: hidden;
        box-shadow: 0 4px 24px rgba(20,17,11,0.07);
        border: 1px solid #E7DCC5;
        transition: transform 0.28s ease, box-shadow 0.28s ease;
        display: flex;
        flex-direction: column;
    }

    .room-card:hover {
        transform: translateY(-6px);
        box-shadow: 0 18px 40px rgba(20,17,11,0.14);
    }

    .room-photo-wrapper {
        position: relative;
        height: 220px;
        overflow: hidden;
        background: #2A2010;
    }

    .room-photo {
        position: absolute;
        inset: 0;
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform 0.45s ease;
        z-index: 2;
    }

    .room-card:hover .room-photo { transform: scale(1.05); }

    .room-photo-placeholder {
        position: absolute;
        inset: 0;
        width: 100%;
        height: 100%;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 6px;
        color: rgba(255,255,255,0.92);
        z-index: 1;
    }

    .placeholder-standard { background: linear-gradient(135deg, #4A3A17 0%, #14110B 100%); }
    .placeholder-suite    { background: linear-gradient(135deg, #6E4E15 0%, #2A1C08 100%); }
    .placeholder-deluxe   { background: linear-gradient(135deg, #B8943D 0%, #4A3A17 100%); }
    .placeholder-single   { background: linear-gradient(135deg, #3A2E14 0%, #14110B 100%); }
    .placeholder-double   { background: linear-gradient(135deg, #5A4218 0%, #14110B 100%); }
    .placeholder-family   { background: linear-gradient(135deg, #8C6A23 0%, #2A1C08 100%); }

    .placeholder-icon { font-size: 2.6rem; opacity: 0.85; }
    .placeholder-type {
        font-size: 0.85rem;
        font-weight: 600;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: #D9B95F;
    }
    .placeholder-brand {
        font-family: Georgia, serif;
        font-size: 0.78rem;
        color: rgba(245,235,199,0.55);
        letter-spacing: 0.12em;
    }

    .availability-badge {
        position: absolute;
        top: 14px;
        right: 14px;
        padding: 5px 14px;
        border-radius: 20px;
        font-size: 0.72rem;
        font-weight: 600;
        letter-spacing: 0.05em;
        text-transform: uppercase;
        z-index: 3;
        backdrop-filter: blur(6px);
    }

    .badge-available   { background: rgba(212,237,218,0.92); color: #1a6e34; }
    .badge-unavailable { background: rgba(248,215,218,0.92); color: #842029; }

    .room-body {
        padding: 22px 22px 20px;
        flex: 1;
        display: flex;
        flex-direction: column;
    }

    .room-header-row {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 10px;
    }

    .room-number {
        font-family: Georgia, serif;
        font-size: 1.15rem;
        font-weight: 600;
        color: #14110B;
    }

    .room-type-tag {
        background: #FAF3E0;
        color: #8C6A23;
        font-size: 0.7rem;
        font-weight: 700;
        padding: 4px 10px;
        border-radius: 12px;
        letter-spacing: 0.06em;
        text-transform: uppercase;
        border: 1px solid #E7DCC5;
    }

    .room-description {
        font-size: 0.9rem;
        color: #6F6657;
        line-height: 1.55;
        margin-bottom: 16px;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    .room-meta {
        display: flex;
        gap: 18px;
        margin-bottom: 18px;
        font-size: 0.85rem;
        color: #6F6657;
    }

    .meta-item { display: flex; align-items: center; gap: 6px; }
    .meta-icon { font-size: 0.95rem; }

    .room-footer {
        margin-top: auto;
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding-top: 16px;
        border-top: 1px solid #E7DCC5;
    }

    .room-price { display: flex; align-items: baseline; gap: 4px; }

    .price-amount {
        font-family: Georgia, serif;
        font-size: 1.45rem;
        font-weight: 600;
        color: #14110B;
    }

    .price-per {
        font-size: 0.78rem;
        color: #9C8E72;
        letter-spacing: 0.04em;
    }

    .btn-book {
        background: #14110B;
        color: #F5EBC7;
        border: 1px solid #14110B;
        padding: 10px 22px;
        border-radius: 24px;
        font-size: 0.82rem;
        font-weight: 600;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        cursor: pointer;
        text-decoration: none;
        display: inline-block;
        transition: all 0.22s ease;
    }

    .btn-book:hover {
        background: #D9B95F;
        color: #14110B;
        border-color: #D9B95F;
        text-decoration: none;
        transform: translateY(-1px);
    }

    .btn-book-disabled {
        background: #E7DCC5;
        color: #9C8E72;
        border-color: #E7DCC5;
        cursor: not-allowed;
    }

    .btn-book-disabled:hover {
        background: #E7DCC5;
        color: #9C8E72;
        transform: none;
    }

    .booking-toast {
        max-width: 520px;
        margin: 0 auto 28px;
        background: #FAF3E0;
        color: #14110B;
        border: 1px solid #D9B95F;
        padding: 14px 22px;
        border-radius: 12px;
        text-align: center;
        font-weight: 500;
        box-shadow: 0 4px 18px rgba(217,185,95,0.18);
    }

    @@media (max-width: 720px) {
        .filter-controls { gap: 10px; }
        .filter-search { flex-basis: 100%; }
        .filter-select { flex: 1 1 calc(50% - 6px); }
    }

    @@media (max-width: 576px) {
        .rooms-grid { grid-template-columns: 1fr; }
        .rooms-title { font-size: 1.9rem; }
    }
</style>

@code {
    private static readonly string[] RoomTypes =
        new[] { "All", "Deluxe" };

    private List<Room>? rooms;
    private int? bookingRoomId;
    private string? bookingMessage;

    private string selectedType = "All";
    private int capacityFilter = 0;
    private string priceFilter = "";
    private string sortBy = "default";
    private bool onlyAvailable;
    private string searchTerm = "";

    private bool HasActiveFilters =>
        selectedType != "All"
        || capacityFilter > 0
        || !string.IsNullOrEmpty(priceFilter)
        || sortBy != "default"
        || onlyAvailable
        || !string.IsNullOrWhiteSpace(searchTerm);

    private List<Room> FilteredRooms
    {
        get
        {
            if (rooms is null) return new();

            IEnumerable<Room> q = rooms;

            if (selectedType != "All")
                q = q.Where(r => string.Equals(r.RoomType, selectedType, StringComparison.OrdinalIgnoreCase));

            if (capacityFilter > 0)
                q = q.Where(r => r.Capacity >= capacityFilter);

            q = priceFilter switch
            {
                "under-300" => q.Where(r => r.PricePerNight < 300m),
                "300-600"   => q.Where(r => r.PricePerNight >= 300m && r.PricePerNight < 600m),
                "600-900"   => q.Where(r => r.PricePerNight >= 600m && r.PricePerNight < 900m),
                "over-900"  => q.Where(r => r.PricePerNight >= 900m),
                _ => q
            };

            if (onlyAvailable)
                q = q.Where(r => r.IsAvailable);

            if (!string.IsNullOrWhiteSpace(searchTerm))
            {
                var s = searchTerm.Trim();
                q = q.Where(r =>
                    (r.RoomNumber ?? "").Contains(s, StringComparison.OrdinalIgnoreCase) ||
                    (r.RoomType ?? "").Contains(s, StringComparison.OrdinalIgnoreCase) ||
                    (r.Description ?? "").Contains(s, StringComparison.OrdinalIgnoreCase));
            }

            q = sortBy switch
            {
                "price-asc"      => q.OrderBy(r => r.PricePerNight),
                "price-desc"     => q.OrderByDescending(r => r.PricePerNight),
                "capacity-desc"  => q.OrderByDescending(r => r.Capacity).ThenBy(r => r.PricePerNight),
                _ => q.OrderBy(r => !r.IsAvailable).ThenBy(r => r.PricePerNight)
            };

            return q.ToList();
        }
    }

    protected override async Task OnInitializedAsync()
    {
        rooms = await Mediator.Send(new GetAllRoomsQuery());
    }

    private void SetType(string type) => selectedType = type;

    private void ClearFilters()
    {
        selectedType   = "All";
        capacityFilter = 0;
        priceFilter    = "";
        sortBy         = "default";
        onlyAvailable  = false;
        searchTerm     = "";
    }

    private async Task BookRoom(Room room)
    {
        bookingRoomId = room.Id;
        bookingMessage = null;

        var auth = await AuthState.GetAuthenticationStateAsync();
        var user = await UserManager.GetUserAsync(auth.User);
        if (user is null)
        {
            Nav.NavigateTo("/login?returnUrl=/rooms");
            return;
        }

        await Mediator.Send(new UpdateRoomCommand(
            room.Id,
            room.RoomNumber,
            room.RoomType,
            room.Description,
            room.PricePerNight,
            room.Capacity,
            IsAvailable: false,
            room.PhotoPath,
            ReservedByUserId: user.Id,
            UpdateReservation: true));

        rooms = await Mediator.Send(new GetAllRoomsQuery());
        bookingMessage = $"Room {room.RoomNumber} reserved. We look forward to your stay.";
        bookingRoomId = null;
    }

    private string GetPlaceholderClass(string roomType) =>
        roomType.ToLowerInvariant() switch
        {
            "suite"   => "placeholder-suite",
            "deluxe"  => "placeholder-deluxe",
            "single"  => "placeholder-single",
            "double"  => "placeholder-double",
            "family"  => "placeholder-family",
            _         => "placeholder-standard"
        };
}
