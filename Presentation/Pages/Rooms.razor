@page "/rooms"
@rendermode RenderMode.InteractiveServer
@using Hotel.Domain.Entities
@using Hotel.Application.Requests.Queries
@using Hotel.Application.Requests.Commands
@using MediatR
@inject IMediator Mediator
@inject NavigationManager Nav

<PageTitle>Our Rooms - Hotel</PageTitle>

<div class="rooms-page">
    <div class="rooms-hero">
        <h1 class="rooms-title">Our Rooms</h1>
        <p class="rooms-subtitle">Discover comfort and elegance in every corner</p>

        <div class="rooms-filter mt-3">
            <a class="filter-btn @(showOnlyAvailable ? "" : "active")" href="/rooms">
                All Rooms
            </a>
            <a class="filter-btn @(showOnlyAvailable ? "active" : "")" href="/rooms?available=true">
                Available Only
            </a>
        </div>
    </div>

    @if (!string.IsNullOrEmpty(bookingMessage))
    {
        <div class="booking-toast">@bookingMessage</div>
    }

    @if (rooms is null)
    {
        <div class="loading-state">
            <div class="spinner-border text-primary" role="status"></div>
            <p class="mt-3 text-muted">Loading rooms...</p>
        </div>
    }
    else if (FilteredRooms.Count == 0)
    {
        <div class="empty-state">
            <div class="empty-icon">🛏️</div>
            <h4>No rooms found</h4>
            <p class="text-muted">Try changing the filter or check back later.</p>
        </div>
    }
    else
    {
        <div class="rooms-grid">
            @foreach (var room in FilteredRooms)
            {
                <div class="room-card">
                    <div class="room-photo-wrapper">
                        @if (!string.IsNullOrEmpty(room.PhotoPath))
                        {
                            <img src="@room.PhotoPath" alt="Room @room.RoomNumber" class="room-photo" />
                        }
                        else
                        {
                            <div class="room-photo-placeholder @GetPlaceholderClass(room.RoomType)">
                                <span class="placeholder-icon">🛏️</span>
                                <span class="placeholder-type">@room.RoomType</span>
                            </div>
                        }

                        <span class="availability-badge @(room.IsAvailable ? "badge-available" : "badge-unavailable")">
                            @(room.IsAvailable ? "Available" : "Not Available")
                        </span>
                    </div>

                    <div class="room-body">
                        <div class="room-header-row">
                            <span class="room-number">Room @room.RoomNumber</span>
                            <span class="room-type-tag">@room.RoomType</span>
                        </div>

                        @if (!string.IsNullOrEmpty(room.Description))
                        {
                            <p class="room-description">@room.Description</p>
                        }

                        <div class="room-meta">
                            <div class="meta-item">
                                <span class="meta-icon">👥</span>
                                <span>@room.Capacity @(room.Capacity == 1 ? "guest" : "guests")</span>
                            </div>
                            <div class="meta-item">
                                <span class="meta-icon">🏷️</span>
                                <span>@room.RoomType</span>
                            </div>
                        </div>

                        <div class="room-footer">
                            <div class="room-price">
                                <span class="price-amount">@room.PricePerNight.ToString("C0")</span>
                                <span class="price-per">/ night</span>
                            </div>

                            <AuthorizeView>
                                <Authorized>
                                    @if (room.IsAvailable)
                                    {
                                        <button class="btn-book" @onclick="() => BookRoom(room)" disabled="@(bookingRoomId == room.Id)">
                                            @(bookingRoomId == room.Id ? "Booking..." : "Book Now")
                                        </button>
                                    }
                                    else
                                    {
                                        <button class="btn-book btn-book-disabled" disabled>Unavailable</button>
                                    }
                                </Authorized>
                                <NotAuthorized>
                                    <a class="btn-book" href="/login?returnUrl=/rooms">Book Now</a>
                                </NotAuthorized>
                            </AuthorizeView>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

<style>
    .rooms-page {
        padding: 0 0 48px 0;
    }

    .rooms-hero {
        background: linear-gradient(135deg, #1a1f2e 0%, #2c3555 100%);
        color: white;
        text-align: center;
        padding: 56px 24px 40px;
        margin-bottom: 40px;
        border-radius: 0 0 24px 24px;
    }

    .rooms-title {
        font-size: 2.4rem;
        font-weight: 700;
        margin-bottom: 8px;
        letter-spacing: -0.5px;
    }

    .rooms-subtitle {
        font-size: 1.1rem;
        color: rgba(255,255,255,0.75);
        margin-bottom: 0;
    }

    .rooms-filter {
        display: flex;
        gap: 8px;
        justify-content: center;
    }

    .filter-btn {
        background: rgba(255,255,255,0.12);
        border: 1px solid rgba(255,255,255,0.25);
        color: rgba(255,255,255,0.8);
        padding: 8px 20px;
        border-radius: 20px;
        font-size: 0.9rem;
        transition: all 0.2s;
        text-decoration: none;
        display: inline-block;
    }

    .filter-btn.active,
    .filter-btn:hover {
        background: white;
        color: #1a1f2e;
        border-color: white;
        text-decoration: none;
    }

    .loading-state, .empty-state {
        text-align: center;
        padding: 80px 24px;
    }

    .empty-icon { font-size: 3rem; margin-bottom: 16px; }

    .rooms-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
        gap: 28px;
        padding: 0 8px;
    }

    .room-card {
        background: white;
        border-radius: 16px;
        overflow: hidden;
        box-shadow: 0 4px 20px rgba(0,0,0,0.08);
        transition: transform 0.25s, box-shadow 0.25s;
    }

    .room-card:hover {
        transform: translateY(-4px);
        box-shadow: 0 12px 32px rgba(0,0,0,0.14);
    }

    .room-photo-wrapper {
        position: relative;
        height: 200px;
        overflow: hidden;
    }

    .room-photo {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform 0.4s;
    }

    .room-card:hover .room-photo {
        transform: scale(1.04);
    }

    .room-photo-placeholder {
        width: 100%;
        height: 100%;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 8px;
    }

    .placeholder-standard { background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); }
    .placeholder-suite     { background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%); }
    .placeholder-deluxe    { background: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%); }
    .placeholder-single    { background: linear-gradient(135deg, #43e97b 0%, #38f9d7 100%); }
    .placeholder-double    { background: linear-gradient(135deg, #fa709a 0%, #fee140 100%); }
    .placeholder-family    { background: linear-gradient(135deg, #a18cd1 0%, #fbc2eb 100%); }

    .placeholder-icon { font-size: 2.5rem; color: rgba(255,255,255,0.85); }
    .placeholder-type { font-size: 0.85rem; color: rgba(255,255,255,0.7); font-weight: 500; }

    .availability-badge {
        position: absolute;
        top: 12px;
        right: 12px;
        padding: 4px 12px;
        border-radius: 20px;
        font-size: 0.78rem;
        font-weight: 600;
    }

    .badge-available   { background: #d4edda; color: #1a6e34; }
    .badge-unavailable { background: #f8d7da; color: #842029; }

    .room-body {
        padding: 20px;
    }

    .room-header-row {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 10px;
    }

    .room-number {
        font-size: 1.1rem;
        font-weight: 700;
        color: #1a1f2e;
    }

    .room-type-tag {
        background: #eef0ff;
        color: #4060b0;
        font-size: 0.75rem;
        font-weight: 600;
        padding: 3px 10px;
        border-radius: 12px;
    }

    .room-description {
        font-size: 0.88rem;
        color: #6c757d;
        line-height: 1.5;
        margin-bottom: 14px;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    .room-meta {
        display: flex;
        gap: 16px;
        margin-bottom: 16px;
        font-size: 0.85rem;
        color: #555;
    }

    .meta-item {
        display: flex;
        align-items: center;
        gap: 5px;
    }

    .meta-icon { font-size: 1rem; }

    .room-footer {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding-top: 14px;
        border-top: 1px solid #f0f0f0;
    }

    .room-price {
        display: flex;
        align-items: baseline;
        gap: 4px;
    }

    .price-amount {
        font-size: 1.35rem;
        font-weight: 700;
        color: #1a1f2e;
    }

    .price-per {
        font-size: 0.8rem;
        color: #999;
    }

    .btn-book {
        background: linear-gradient(135deg, #1a1f2e, #2c3555);
        color: white;
        border: none;
        padding: 9px 20px;
        border-radius: 10px;
        font-size: 0.88rem;
        font-weight: 600;
        cursor: pointer;
        text-decoration: none;
        display: inline-block;
        transition: opacity 0.2s, transform 0.1s;
    }

    .btn-book:hover {
        opacity: 0.88;
        color: white;
        text-decoration: none;
        transform: translateY(-1px);
    }

    .btn-book-disabled {
        background: #d0d0d0;
        cursor: not-allowed;
    }

    .btn-book-disabled:hover {
        opacity: 1;
        transform: none;
    }

    .booking-toast {
        max-width: 480px;
        margin: 0 auto 24px;
        background: #d4edda;
        color: #1a6e34;
        border: 1px solid #b6dec0;
        padding: 12px 20px;
        border-radius: 10px;
        text-align: center;
        font-weight: 600;
    }

    @@media (max-width: 576px) {
        .rooms-grid { grid-template-columns: 1fr; }
        .rooms-title { font-size: 1.8rem; }
    }
</style>

@code {
    [SupplyParameterFromQuery(Name = "available")]
    public bool showOnlyAvailable { get; set; }

    private List<Room>? rooms;
    private int? bookingRoomId;
    private string? bookingMessage;

    private List<Room> FilteredRooms =>
        showOnlyAvailable ? rooms?.Where(r => r.IsAvailable).ToList() ?? [] : rooms ?? [];

    protected override async Task OnInitializedAsync()
    {
        rooms = await Mediator.Send(new GetAllRoomsQuery());
    }

    private async Task BookRoom(Room room)
    {
        bookingRoomId = room.Id;
        bookingMessage = null;

        await Mediator.Send(new UpdateRoomCommand(
            room.Id,
            room.RoomNumber,
            room.RoomType,
            room.Description,
            room.PricePerNight,
            room.Capacity,
            IsAvailable: false,
            room.PhotoPath));

        rooms = await Mediator.Send(new GetAllRoomsQuery());
        bookingMessage = $"Room {room.RoomNumber} booked successfully!";
        bookingRoomId = null;
    }

    private string GetPlaceholderClass(string roomType) =>
        roomType.ToLowerInvariant() switch
        {
            "suite"   => "placeholder-suite",
            "deluxe"  => "placeholder-deluxe",
            "single"  => "placeholder-single",
            "double"  => "placeholder-double",
            "family"  => "placeholder-family",
            _         => "placeholder-standard"
        };
}
