@page "/"

<PageTitle>Hotel - Welcome</PageTitle>

<div class="hero-section">
    <div class="hero-content">
        <div class="hero-badge">&#x2B50; Premium Hotel Experience</div>
        <h1 class="hero-title">Your Perfect Stay<br />Awaits You</h1>
        <p class="hero-subtitle">
            Discover our carefully curated rooms, world-class amenities,
            and exceptional service — all in one place.
        </p>
        <div class="hero-actions">
            <a href="/rooms" class="hero-btn-primary">Browse Rooms</a>
            <a href="/register" class="hero-btn-secondary">Create Account</a>
        </div>
    </div>
    <div class="hero-visual">
        <div class="hero-card-float card-1">
            <span>&#x1F6CF;</span>
            <div>
                <div class="hc-title">Luxury Suites</div>
                <div class="hc-sub">Starting at 299 RON/night</div>
            </div>
        </div>
        <div class="hero-card-float card-2">
            <span>&#x2B50;</span>
            <div>
                <div class="hc-title">Top Rated</div>
                <div class="hc-sub">4.9 / 5 guest score</div>
            </div>
        </div>
        <div class="hero-card-float card-3">
            <span>&#x1F511;</span>
            <div>
                <div class="hc-title">Easy Booking</div>
                <div class="hc-sub">Reserve in seconds</div>
            </div>
        </div>
    </div>
</div>

<div class="features-row">
    <div class="feature-item">
        <div class="feat-icon">&#x1F6CF;</div>
        <div class="feat-title">Comfortable Rooms</div>
        <div class="feat-desc">Singles, doubles, suites, and family rooms to suit every need.</div>
    </div>
    <div class="feature-item">
        <div class="feat-icon">&#x1F4B3;</div>
        <div class="feat-title">Transparent Pricing</div>
        <div class="feat-desc">Clear nightly rates with no hidden fees or surprises.</div>
    </div>
    <div class="feature-item">
        <div class="feat-icon">&#x1F4F1;</div>
        <div class="feat-title">Simple Booking</div>
        <div class="feat-desc">Browse availability and reserve your room in just a few clicks.</div>
    </div>
    <div class="feature-item">
        <div class="feat-icon">&#x1F91D;</div>
        <div class="feat-title">Dedicated Support</div>
        <div class="feat-desc">Our reception team is always here to help you.</div>
    </div>
</div>

<div class="cta-section">
    <h2 class="cta-title">Ready to book your stay?</h2>
    <p class="cta-sub">Browse our available rooms and find the perfect fit.</p>
    <a href="/rooms" class="cta-btn">View All Rooms &#x2192;</a>
</div>

<style>
    .hero-section {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 40px;
        padding: 56px 0 48px;
        flex-wrap: wrap;
    }

    .hero-content { max-width: 520px; }

    .hero-badge {
        display: inline-block;
        background: #fff3e0;
        color: #b86a00;
        font-size: 0.78rem;
        font-weight: 700;
        padding: 5px 14px;
        border-radius: 20px;
        margin-bottom: 16px;
        letter-spacing: 0.03em;
    }

    .hero-title {
        font-size: 2.8rem;
        font-weight: 800;
        color: #0f1624;
        line-height: 1.15;
        margin-bottom: 16px;
    }

    .hero-subtitle {
        font-size: 1rem;
        color: #5a6880;
        line-height: 1.65;
        margin-bottom: 28px;
        max-width: 440px;
    }

    .hero-actions { display: flex; gap: 12px; flex-wrap: wrap; }

    .hero-btn-primary {
        background: linear-gradient(135deg, #1a2a6c, #3060e0);
        color: white;
        padding: 13px 28px;
        border-radius: 10px;
        text-decoration: none;
        font-weight: 700;
        font-size: 0.95rem;
        transition: opacity 0.2s, transform 0.15s;
        display: inline-block;
    }

    .hero-btn-primary:hover { color: white; text-decoration: none; opacity: 0.88; transform: translateY(-1px); }

    .hero-btn-secondary {
        background: white;
        color: #3060e0;
        padding: 13px 28px;
        border-radius: 10px;
        text-decoration: none;
        font-weight: 700;
        font-size: 0.95rem;
        border: 2px solid #c0d4f8;
        transition: border-color 0.18s, background 0.18s;
        display: inline-block;
    }

    .hero-btn-secondary:hover { border-color: #3060e0; background: #f0f5ff; text-decoration: none; }

    .hero-visual {
        display: flex;
        flex-direction: column;
        gap: 14px;
        min-width: 240px;
    }

    .hero-card-float {
        background: white;
        border-radius: 14px;
        padding: 16px 20px;
        display: flex;
        align-items: center;
        gap: 14px;
        box-shadow: 0 4px 20px rgba(0,0,0,0.08);
        font-size: 1.5rem;
        animation: floatCard 3s ease-in-out infinite;
    }

    .card-1 { animation-delay: 0s; }
    .card-2 { animation-delay: 0.4s; }
    .card-3 { animation-delay: 0.8s; }

    @@keyframes floatCard {
        0%, 100% { transform: translateY(0); }
        50%       { transform: translateY(-6px); }
    }

    .hc-title { font-size: 0.875rem; font-weight: 700; color: #0f1624; }
    .hc-sub   { font-size: 0.75rem; color: #8896a8; margin-top: 2px; }

    /* Features */
    .features-row {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 20px;
        margin: 16px 0 48px;
    }

    .feature-item {
        background: white;
        border-radius: 14px;
        padding: 24px 20px;
        text-align: center;
        box-shadow: 0 2px 12px rgba(0,0,0,0.05);
        transition: transform 0.2s;
    }

    .feature-item:hover { transform: translateY(-3px); }

    .feat-icon { font-size: 2rem; margin-bottom: 10px; }
    .feat-title { font-size: 0.95rem; font-weight: 700; color: #0f1624; margin-bottom: 6px; }
    .feat-desc { font-size: 0.82rem; color: #6c757d; line-height: 1.5; }

    /* CTA */
    .cta-section {
        background: linear-gradient(135deg, #1a2a6c 0%, #3060e0 60%, #6090f0 100%);
        border-radius: 20px;
        padding: 48px 40px;
        text-align: center;
        margin-bottom: 16px;
    }

    .cta-title {
        font-size: 1.8rem;
        font-weight: 800;
        color: white;
        margin-bottom: 10px;
    }

    .cta-sub { color: rgba(255,255,255,0.78); font-size: 1rem; margin-bottom: 24px; }

    .cta-btn {
        background: white;
        color: #1a2a6c;
        padding: 13px 32px;
        border-radius: 10px;
        text-decoration: none;
        font-weight: 700;
        font-size: 0.95rem;
        transition: opacity 0.2s;
        display: inline-block;
    }

    .cta-btn:hover { opacity: 0.9; text-decoration: none; color: #1a2a6c; }

    @@media (max-width: 768px) {
        .hero-title { font-size: 2rem; }
        .hero-visual { display: none; }
        .features-row { grid-template-columns: 1fr 1fr; }
    }

    @@media (max-width: 480px) {
        .features-row { grid-template-columns: 1fr; }
        .cta-section { padding: 32px 20px; }
    }
</style>
