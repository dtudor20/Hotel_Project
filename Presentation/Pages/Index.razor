@page "/"

<PageTitle>AurumStay — A quieter way to arrive</PageTitle>

<section class="hero-cinematic">
    <div class="hero-overlay"></div>
    <div class="hero-content">
        <span class="hero-eyebrow">AurumStay · est. 2025</span>
        <h1 class="hero-headline">
            A quieter way<br />
            <em>to arrive.</em>
        </h1>
        <p class="hero-lede">
            Hand-finished rooms, calm interiors, and an arrival without friction.
            AurumStay is the small luxury of being expected.
        </p>
        <div class="hero-actions">
            <a href="/rooms" class="hero-cta-primary">Check availability</a>
            <a href="/rooms" class="hero-cta-secondary">Discover rooms</a>
        </div>
    </div>
    <div class="hero-scroll-hint">
        <span>Scroll</span>
        <span class="hint-line"></span>
    </div>
</section>

<section class="story-section">
    <span class="section-eyebrow">The experience</span>
    <h2 class="section-headline">Designed around the way you stay.</h2>
    <p class="section-lede">
        Every room is composed — not assembled. From the linens you wake into to the light
        that finds the desk in the afternoon, AurumStay is the unhurried version of staying
        somewhere new.
    </p>
</section>

<section class="features-row">
    <div class="feature-item">
        <div class="feat-rule"></div>
        <div class="feat-title">Composed rooms</div>
        <div class="feat-desc">Singles, doubles, and suites — finished by hand, kept by people who care.</div>
    </div>
    <div class="feature-item">
        <div class="feat-rule"></div>
        <div class="feat-title">Honest pricing</div>
        <div class="feat-desc">A nightly rate that holds. No surprise lines on your bill.</div>
    </div>
    <div class="feature-item">
        <div class="feat-rule"></div>
        <div class="feat-title">Effortless arrival</div>
        <div class="feat-desc">Reserve in a few clicks. Walk in already expected.</div>
    </div>
    <div class="feature-item">
        <div class="feat-rule"></div>
        <div class="feat-title">Attentive service</div>
        <div class="feat-desc">A small team, always reachable, never in the way.</div>
    </div>
</section>

<section class="cta-section">
    <div class="cta-frame">
        <span class="section-eyebrow light">Begin your stay</span>
        <h2 class="cta-title">A room is waiting.</h2>
        <p class="cta-sub">Browse our rooms and reserve in moments.</p>
        <a href="/rooms" class="cta-btn">View all rooms &rarr;</a>
    </div>
</section>

<style>
    /* ── Cinematic hero ── */
    .hero-cinematic {
        position: relative;
        min-height: 78vh;
        margin: -24px -28px 0;
        background-image:
            linear-gradient(180deg, rgba(20,17,11,0.35) 0%, rgba(20,17,11,0.55) 60%, rgba(20,17,11,0.92) 100%),
            radial-gradient(ellipse at 50% 35%, rgba(217,185,95,0.20), transparent 70%),
            linear-gradient(135deg, #2A2010 0%, #14110B 60%, #050505 100%);
        background-size: cover;
        background-position: center;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        padding: 80px 28px 100px;
        color: #F5EBC7;
        overflow: hidden;
        animation: heroFade 1.6s ease-out;
    }

    @@keyframes heroFade {
        from { opacity: 0; transform: scale(1.02); }
        to   { opacity: 1; transform: scale(1); }
    }

    .hero-overlay {
        position: absolute;
        inset: 0;
        background: radial-gradient(circle at 80% 20%, rgba(217,185,95,0.10), transparent 60%);
        pointer-events: none;
    }

    .hero-content {
        position: relative;
        z-index: 2;
        max-width: 760px;
        text-align: center;
        animation: heroRise 1.4s 0.2s ease-out backwards;
    }

    @@keyframes heroRise {
        from { opacity: 0; transform: translateY(20px); }
        to   { opacity: 1; transform: translateY(0); }
    }

    .hero-eyebrow {
        display: inline-block;
        font-size: 0.72rem;
        letter-spacing: 0.32em;
        text-transform: uppercase;
        color: #D9B95F;
        margin-bottom: 28px;
    }

    .hero-headline {
        font-family: Georgia, "Times New Roman", serif;
        font-weight: 400;
        font-size: clamp(2.6rem, 6.4vw, 4.6rem);
        line-height: 1.05;
        letter-spacing: -1.5px;
        color: #F7F1E6;
        margin-bottom: 26px;
    }

    .hero-headline em {
        font-style: italic;
        color: #D9B95F;
    }

    .hero-lede {
        font-size: 1.04rem;
        line-height: 1.7;
        color: rgba(245,235,199,0.78);
        max-width: 540px;
        margin: 0 auto 38px;
    }

    .hero-actions {
        display: flex;
        gap: 14px;
        justify-content: center;
        flex-wrap: wrap;
    }

    .hero-cta-primary {
        background: #D9B95F;
        color: #14110B;
        padding: 14px 32px;
        border-radius: 26px;
        font-size: 0.82rem;
        font-weight: 700;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        text-decoration: none;
        transition: all 0.25s ease;
        display: inline-block;
        box-shadow: 0 8px 28px rgba(217,185,95,0.30);
    }

    .hero-cta-primary:hover {
        background: #F5DEA0;
        color: #14110B;
        text-decoration: none;
        transform: translateY(-2px);
    }

    .hero-cta-secondary {
        background: transparent;
        color: #F5EBC7;
        padding: 14px 32px;
        border-radius: 26px;
        border: 1px solid rgba(245,235,199,0.45);
        font-size: 0.82rem;
        font-weight: 600;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        text-decoration: none;
        transition: all 0.25s ease;
        display: inline-block;
    }

    .hero-cta-secondary:hover {
        background: rgba(245,235,199,0.10);
        color: #F5EBC7;
        border-color: #F5EBC7;
        text-decoration: none;
    }

    .hero-scroll-hint {
        position: absolute;
        bottom: 24px;
        left: 50%;
        transform: translateX(-50%);
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 8px;
        font-size: 0.66rem;
        letter-spacing: 0.32em;
        text-transform: uppercase;
        color: rgba(245,235,199,0.50);
        animation: scrollPulse 2.4s ease-in-out infinite;
    }

    .hint-line {
        width: 1px;
        height: 28px;
        background: linear-gradient(180deg, rgba(245,235,199,0.50), transparent);
    }

    @@keyframes scrollPulse {
        0%, 100% { opacity: 0.5; transform: translate(-50%, 0); }
        50%      { opacity: 1;   transform: translate(-50%, 6px); }
    }

    /* ── Story section ── */
    .story-section {
        max-width: 720px;
        margin: 96px auto 64px;
        text-align: center;
        padding: 0 16px;
    }

    .section-eyebrow {
        display: inline-block;
        font-size: 0.70rem;
        letter-spacing: 0.28em;
        text-transform: uppercase;
        color: #B8943D;
        margin-bottom: 18px;
    }

    .section-eyebrow.light { color: #D9B95F; }

    .section-headline {
        font-family: Georgia, serif;
        font-size: clamp(1.8rem, 3.6vw, 2.6rem);
        font-weight: 500;
        line-height: 1.2;
        color: #14110B;
        margin-bottom: 22px;
        letter-spacing: -0.5px;
    }

    .section-lede {
        font-size: 1.02rem;
        line-height: 1.75;
        color: #6F6657;
        max-width: 580px;
        margin: 0 auto;
    }

    /* ── Features ── */
    .features-row {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 28px;
        max-width: 1100px;
        margin: 0 auto 80px;
        padding: 0 16px;
    }

    .feature-item {
        background: transparent;
        padding: 28px 8px 20px;
        text-align: left;
        transition: transform 0.25s;
    }

    .feature-item:hover { transform: translateY(-3px); }

    .feat-rule {
        width: 30px;
        height: 2px;
        background: #D9B95F;
        margin-bottom: 18px;
    }

    .feat-title {
        font-family: Georgia, serif;
        font-size: 1.05rem;
        font-weight: 600;
        color: #14110B;
        margin-bottom: 10px;
    }

    .feat-desc {
        font-size: 0.88rem;
        color: #6F6657;
        line-height: 1.6;
    }

    /* ── CTA ── */
    .cta-section {
        padding: 0 0 80px;
    }

    .cta-frame {
        background: linear-gradient(135deg, #14110B 0%, #2A2010 60%, #14110B 100%);
        border-radius: 24px;
        padding: 64px 40px;
        text-align: center;
        position: relative;
        overflow: hidden;
        border: 1px solid rgba(217,185,95,0.20);
    }

    .cta-frame::before {
        content: "";
        position: absolute;
        inset: 0;
        background: radial-gradient(circle at 30% 30%, rgba(217,185,95,0.18), transparent 60%);
        pointer-events: none;
    }

    .cta-title {
        font-family: Georgia, serif;
        font-size: clamp(1.8rem, 3.4vw, 2.4rem);
        font-weight: 500;
        color: #F7F1E6;
        margin-bottom: 14px;
        position: relative;
    }

    .cta-sub {
        color: rgba(245,235,199,0.70);
        font-size: 1rem;
        margin-bottom: 28px;
        position: relative;
    }

    .cta-btn {
        background: #D9B95F;
        color: #14110B;
        padding: 13px 32px;
        border-radius: 26px;
        text-decoration: none;
        font-weight: 700;
        font-size: 0.82rem;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        transition: all 0.25s ease;
        display: inline-block;
        position: relative;
        box-shadow: 0 8px 28px rgba(217,185,95,0.30);
    }

    .cta-btn:hover {
        background: #F5DEA0;
        color: #14110B;
        text-decoration: none;
        transform: translateY(-2px);
    }

    @@media (max-width: 900px) {
        .features-row { grid-template-columns: 1fr 1fr; gap: 22px; }
    }

    @@media (max-width: 560px) {
        .hero-cinematic { min-height: 70vh; padding: 56px 22px 70px; }
        .features-row { grid-template-columns: 1fr; }
        .cta-frame { padding: 44px 24px; }
    }
</style>
