@page "/admin"
@rendermode RenderMode.InteractiveServer
@layout AdminLayout
@attribute [Authorize]
@using Hotel.Application.Requests.Queries
@using Hotel.Domain.Entities
@using MediatR
@using Microsoft.AspNetCore.Identity
@inject IMediator Mediator
@inject UserManager<ApplicationUser> UserManager
@inject AuthenticationStateProvider Auth
@inject NavigationManager Nav

<PageTitle>Dashboard — AurumStay Operations</PageTitle>

@if (!initialized)
{
    <div class="d-flex align-items-center gap-3 mt-4">
        <div class="spinner-border text-warning" role="status"></div>
        <span class="text-muted">Loading…</span>
    </div>
}
else
{
    <div class="dashboard-welcome mb-4">
        <h2 class="dashboard-heading">Good day, @(currentUserEmail ?? "Admin")</h2>
        <p class="text-muted mb-0">Here's what's happening at AurumStay today.</p>
    </div>

    <div class="stats-grid mb-5">
        <div class="stat-card stat-gold">
            <div class="stat-icon">&#x1F4B0;</div>
            <div class="stat-body">
                <div class="stat-value">@stats!.TotalRevenue.ToString("C0")</div>
                <div class="stat-label">Revenue (booked)</div>
            </div>
        </div>
        <div class="stat-card stat-bronze">
            <div class="stat-icon">&#x1F4D6;</div>
            <div class="stat-body">
                <div class="stat-value">@stats.ReservationCount</div>
                <div class="stat-label">Active reservations</div>
            </div>
        </div>
        <div class="stat-card stat-cream">
            <div class="stat-icon">&#x25A1;</div>
            <div class="stat-body">
                <div class="stat-value">@stats.AvailableRooms<span class="stat-divider">/ @stats.TotalRooms</span></div>
                <div class="stat-label">Available rooms</div>
            </div>
        </div>
        <div class="stat-card stat-deep">
            <div class="stat-icon">&#x1F465;</div>
            <div class="stat-body">
                <div class="stat-value">@stats.TotalUsers</div>
                <div class="stat-label">Registered guests</div>
            </div>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-lg-7">
            <div class="admin-card h-100">
                <div class="section-row">
                    <h5 class="section-title">Recent reservations</h5>
                    <a href="/admin/rooms" class="section-link">View all rooms &rarr;</a>
                </div>

                @if (stats.RecentReservations.Count == 0)
                {
                    <div class="empty-reservations">
                        <div style="font-size: 2rem; opacity: 0.6;">&#x1F6CF;</div>
                        <p class="text-muted mt-2 mb-0">No reservations yet.</p>
                    </div>
                }
                else
                {
                    <div class="reservations-table-wrap">
                        <table class="reservations-table">
                            <thead>
                                <tr>
                                    <th>Room</th>
                                    <th>Type</th>
                                    <th>Guest</th>
                                    <th>Reserved</th>
                                    <th class="text-end">Amount</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var r in stats.RecentReservations)
                                {
                                    <tr>
                                        <td class="room-cell"><strong>@r.RoomNumber</strong></td>
                                        <td><span class="type-tag">@r.RoomType</span></td>
                                        <td>
                                            @if (!string.IsNullOrEmpty(r.GuestEmail))
                                            {
                                                <div class="guest-cell">
                                                    <span class="guest-dot">@(r.GuestEmail[0].ToString().ToUpper())</span>
                                                    <span class="guest-email">@r.GuestEmail</span>
                                                </div>
                                            }
                                            else
                                            {
                                                <span class="text-muted">— unknown —</span>
                                            }
                                        </td>
                                        <td class="when-cell">@FormatWhen(r.ReservedAt)</td>
                                        <td class="amount-cell text-end">@r.PricePerNight.ToString("C0")</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>

        <div class="col-lg-5">
            <div class="admin-card h-100">
                <h5 class="section-title">Occupancy</h5>
                @{
                    var occupancyPct = stats.TotalRooms > 0
                        ? (int)(((double)(stats.TotalRooms - stats.AvailableRooms) / stats.TotalRooms) * 100)
                        : 0;
                }
                <div class="occupancy-block">
                    <div class="occupancy-numbers">
                        <span class="occ-big">@occupancyPct<span class="occ-pct">%</span></span>
                        <span class="occ-label">Occupied</span>
                    </div>
                    <div class="occ-bar-wrap">
                        <div class="occ-bar">
                            <div class="occ-fill" style="width: @occupancyPct%"></div>
                        </div>
                        <div class="occ-legend">
                            <span class="legend-dot dot-occupied"></span> @(stats.TotalRooms - stats.AvailableRooms) booked &nbsp;
                            <span class="legend-dot dot-available"></span> @stats.AvailableRooms available
                        </div>
                    </div>
                </div>

                <hr class="card-divider" />

                <h5 class="section-title mb-3">Quick actions</h5>
                <div class="quick-actions">
                    <a href="/admin/rooms" class="quick-action-btn">
                        <span class="qa-icon">&#x2795;</span>
                        <div>
                            <div class="qa-title">Add room</div>
                            <div class="qa-desc">New listing with photo and pricing</div>
                        </div>
                    </a>
                    <a href="/admin/users" class="quick-action-btn">
                        <span class="qa-icon">&#x1F464;</span>
                        <div>
                            <div class="qa-title">Manage guests</div>
                            <div class="qa-desc">Suspend, activate and review</div>
                        </div>
                    </a>
                </div>
            </div>
        </div>
    </div>
}

<style>
    .dashboard-heading {
        font-family: Georgia, serif;
        font-size: 1.7rem;
        font-weight: 500;
        color: #F5EBC7;
        letter-spacing: 0.02em;
    }

    .stats-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 20px;
    }

    .stat-card {
        background: #14110B;
        border: 1px solid #2A2010;
        border-radius: 14px;
        padding: 22px 20px;
        display: flex;
        align-items: center;
        gap: 16px;
        box-shadow: 0 2px 18px rgba(0,0,0,0.30);
        border-left: 3px solid transparent;
        transition: transform 0.2s, border-color 0.2s;
    }

    .stat-card:hover { transform: translateY(-2px); border-color: #4A3A17; }

    .stat-gold   { border-left-color: #D9B95F; }
    .stat-bronze { border-left-color: #B8943D; }
    .stat-cream  { border-left-color: #F5EBC7; }
    .stat-deep   { border-left-color: #8C6A23; }

    .stat-icon {
        font-size: 1.5rem;
        width: 48px;
        height: 48px;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 12px;
        background: rgba(217,185,95,0.10);
        color: #D9B95F;
    }

    .stat-value {
        font-family: Georgia, serif;
        font-size: 1.7rem;
        font-weight: 600;
        color: #F5EBC7;
        line-height: 1;
        letter-spacing: 0.01em;
    }

    .stat-divider {
        font-size: 0.95rem;
        color: #B8A878;
        margin-left: 4px;
        font-weight: 400;
    }

    .stat-label {
        font-size: 0.72rem;
        color: #B8A878;
        margin-top: 6px;
        text-transform: uppercase;
        letter-spacing: 0.10em;
    }

    .section-title {
        font-family: Georgia, serif;
        font-size: 1.05rem;
        font-weight: 600;
        color: #F5EBC7;
        letter-spacing: 0.02em;
        margin: 0;
    }

    .section-row {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 18px;
    }

    .section-link {
        font-size: 0.78rem;
        color: #D9B95F;
        text-decoration: none;
        letter-spacing: 0.06em;
    }

    .section-link:hover { color: #F5DEA0; text-decoration: underline; }

    .empty-reservations {
        text-align: center;
        padding: 50px 20px;
        color: #B8A878;
    }

    .reservations-table-wrap { overflow-x: auto; }

    .reservations-table {
        width: 100%;
        border-collapse: collapse;
        font-size: 0.88rem;
        color: #F5EBC7;
    }

    .reservations-table th {
        background: rgba(217,185,95,0.06);
        color: #B8A878;
        font-size: 0.68rem;
        font-weight: 700;
        letter-spacing: 0.10em;
        text-transform: uppercase;
        padding: 11px 14px;
        text-align: left;
        border-bottom: 1px solid #2A2010;
    }

    .reservations-table td {
        padding: 13px 14px;
        border-bottom: 1px solid #2A2010;
        vertical-align: middle;
    }

    .reservations-table tr:last-child td { border-bottom: none; }
    .reservations-table tr:hover td { background: rgba(217,185,95,0.04); }

    .room-cell { color: #F5EBC7; font-family: Georgia, serif; }

    .type-tag {
        background: rgba(217,185,95,0.12);
        color: #D9B95F;
        font-size: 0.7rem;
        font-weight: 700;
        padding: 3px 10px;
        border-radius: 12px;
        letter-spacing: 0.06em;
        text-transform: uppercase;
        border: 1px solid rgba(217,185,95,0.30);
    }

    .guest-cell { display: flex; align-items: center; gap: 10px; }

    .guest-dot {
        width: 30px;
        height: 30px;
        border-radius: 50%;
        background: linear-gradient(135deg, #D9B95F, #B8943D);
        color: #14110B;
        font-weight: 700;
        font-size: 0.75rem;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
    }

    .guest-email { color: #F5EBC7; font-size: 0.88rem; }

    .when-cell { color: #B8A878; font-size: 0.85rem; }
    .amount-cell {
        font-family: Georgia, serif;
        font-weight: 600;
        color: #D9B95F;
    }

    .text-end { text-align: right; }

    .card-divider {
        border: 0;
        border-top: 1px solid #2A2010;
        margin: 26px 0;
    }

    .quick-actions { display: flex; flex-direction: column; gap: 10px; }

    .quick-action-btn {
        display: flex;
        align-items: center;
        gap: 14px;
        padding: 14px 16px;
        background: rgba(217,185,95,0.05);
        border: 1px solid #2A2010;
        border-radius: 10px;
        text-decoration: none !important;
        color: inherit;
        transition: all 0.18s;
    }

    .quick-action-btn:hover {
        background: rgba(217,185,95,0.10);
        border-color: #4A3A17;
        text-decoration: none;
        transform: translateX(3px);
    }

    .qa-icon { font-size: 1.2rem; flex-shrink: 0; color: #D9B95F; }
    .qa-title { font-size: 0.9rem; font-weight: 600; color: #F5EBC7; }
    .qa-desc  { font-size: 0.78rem; color: #B8A878; margin-top: 2px; }

    .occupancy-block { display: flex; align-items: flex-start; gap: 24px; margin: 8px 0 4px; }

    .occupancy-numbers { text-align: center; min-width: 88px; }

    .occ-big {
        display: block;
        font-family: Georgia, serif;
        font-size: 2.4rem;
        font-weight: 600;
        color: #F5EBC7;
        line-height: 1;
    }

    .occ-pct { font-size: 1.1rem; font-weight: 600; color: #D9B95F; }

    .occ-label {
        font-size: 0.7rem;
        color: #B8A878;
        margin-top: 6px;
        display: block;
        text-transform: uppercase;
        letter-spacing: 0.10em;
    }

    .occ-bar-wrap { flex: 1; padding-top: 6px; }

    .occ-bar {
        height: 12px;
        background: rgba(217,185,95,0.10);
        border-radius: 8px;
        overflow: hidden;
        margin-bottom: 12px;
        border: 1px solid #2A2010;
    }

    .occ-fill {
        height: 100%;
        background: linear-gradient(90deg, #B8943D, #D9B95F);
        border-radius: 8px;
        transition: width 0.5s ease;
    }

    .occ-legend { font-size: 0.78rem; color: #B8A878; }
    .legend-dot { display: inline-block; width: 8px; height: 8px; border-radius: 50%; margin-right: 4px; }
    .dot-occupied  { background: #D9B95F; }
    .dot-available { background: #7AB07A; }

    @@media (max-width: 1100px) {
        .stats-grid { grid-template-columns: repeat(2, 1fr); }
    }
    @@media (max-width: 576px) {
        .stats-grid { grid-template-columns: 1fr; }
    }
</style>

@code {
    private DashboardStats? stats;
    private bool initialized = false;
    private string? currentUserEmail;

    protected override async Task OnInitializedAsync()
    {
        var authState = await Auth.GetAuthenticationStateAsync();
        var user = await UserManager.GetUserAsync(authState.User);

        if (user?.IsAdmin != true)
        {
            Nav.NavigateTo("/");
            return;
        }

        currentUserEmail = user.Email?.Split('@')[0];
        stats = await Mediator.Send(new GetDashboardStatsQuery());
        initialized = true;
    }

    private static string FormatWhen(DateTime? at)
    {
        if (at is null) return "—";
        var diff = DateTime.UtcNow - at.Value;
        return diff switch
        {
            { TotalMinutes: < 1 }  => "just now",
            { TotalMinutes: < 60 } => $"{(int)diff.TotalMinutes} min ago",
            { TotalHours:   < 24 } => $"{(int)diff.TotalHours}h ago",
            { TotalDays:    < 7  } => $"{(int)diff.TotalDays}d ago",
            _ => at.Value.ToLocalTime().ToString("MMM d, HH:mm")
        };
    }
}
