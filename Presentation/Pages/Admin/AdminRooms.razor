@page "/admin/rooms"
@rendermode RenderMode.InteractiveServer
@layout AdminLayout
@attribute [Authorize]
@using Hotel.Application.Requests.Commands
@using Hotel.Application.Requests.Queries
@using Hotel.Domain.Entities
@using MediatR
@using Microsoft.AspNetCore.Components.Forms
@using Microsoft.AspNetCore.Identity
@inject IMediator Mediator
@inject UserManager<ApplicationUser> UserManager
@inject AuthenticationStateProvider Auth
@inject NavigationManager Nav
@inject IWebHostEnvironment WebHostEnv

<PageTitle>Rooms - Hotel Admin</PageTitle>

@if (!initialized)
{
    <div class="d-flex align-items-center gap-3">
        <div class="spinner-border text-primary" role="status"></div>
        <span class="text-muted">Loading rooms...</span>
    </div>
}
else
{
    <div class="page-header mb-4">
        <div>
            <h2 class="page-h2">Room Management</h2>
            <p class="text-muted mb-0">Add, edit, and manage hotel rooms with photos.</p>
        </div>
        <button class="btn-admin-primary" @onclick="OpenAddModal">
            &#x2795; Add Room
        </button>
    </div>

    @if (!string.IsNullOrEmpty(successMessage))
    {
        <div class="alert alert-success alert-dismissible mb-4" role="alert">
            @successMessage
            <button type="button" class="btn-close" @onclick="() => successMessage = null"></button>
        </div>
    }

    @if (!string.IsNullOrEmpty(errorMessage))
    {
        <div class="alert alert-danger alert-dismissible mb-4" role="alert">
            @errorMessage
            <button type="button" class="btn-close" @onclick="() => errorMessage = null"></button>
        </div>
    }

    <div class="admin-card">
        @if (rooms.Count == 0)
        {
            <div class="empty-table-state">
                <div style="font-size:2.5rem">&#x1F6CF;</div>
                <p class="mt-2 text-muted">No rooms yet. Click <strong>Add Room</strong> to get started.</p>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="admin-table">
                    <thead>
                        <tr>
                            <th>Photo</th>
                            <th>Room #</th>
                            <th>Type</th>
                            <th>Capacity</th>
                            <th>Price / Night</th>
                            <th>Status</th>
                            <th>Reserved by</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var room in rooms)
                        {
                            <tr>
                                <td>
                                    <div class="table-thumb-wrap">
                                        <div class="table-thumb-placeholder">&#x1F6CF;</div>
                                        @if (!string.IsNullOrEmpty(room.PhotoPath))
                                        {
                                            <img src="@room.PhotoPath" alt="Room @room.RoomNumber"
                                                 class="table-thumb"
                                                 onerror="this.style.display='none'" />
                                        }
                                    </div>
                                </td>
                                <td><strong>@room.RoomNumber</strong></td>
                                <td><span class="type-badge">@room.RoomType</span></td>
                                <td>@room.Capacity</td>
                                <td class="price-cell">@room.PricePerNight.ToString("C")</td>
                                <td>
                                    <span class="status-pill @(room.IsAvailable ? "pill-available" : "pill-unavailable")">
                                        @(room.IsAvailable ? "Available" : "Reserved")
                                    </span>
                                </td>
                                <td>
                                    @if (!room.IsAvailable && room.ReservedByUserId is not null
                                         && userEmails.TryGetValue(room.ReservedByUserId, out var email)
                                         && !string.IsNullOrEmpty(email))
                                    {
                                        <div class="reserver-cell">
                                            <span class="reserver-dot">@(email[0].ToString().ToUpper())</span>
                                            <div class="reserver-info">
                                                <span class="reserver-email">@email</span>
                                                @if (room.ReservedAt is not null)
                                                {
                                                    <span class="reserver-when">@room.ReservedAt.Value.ToLocalTime().ToString("MMM d, HH:mm")</span>
                                                }
                                            </div>
                                        </div>
                                    }
                                    else if (!room.IsAvailable)
                                    {
                                        <span class="text-muted small">— manual hold —</span>
                                    }
                                    else
                                    {
                                        <span class="text-muted small">—</span>
                                    }
                                </td>
                                <td>
                                    <div class="action-btns">
                                        <button class="btn-action btn-edit" @onclick="() => OpenEditModal(room)">
                                            &#x270F;&#xFE0F; Edit
                                        </button>
                                        <button class="btn-action btn-delete" @onclick="() => ConfirmDelete(room)">
                                            &#x1F5D1; Delete
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
}

@* Add / Edit Modal *@
@if (showModal)
{
    <div class="modal-backdrop" @onclick="CloseModal"></div>
    <div class="modal-panel" @onclick:stopPropagation="true">
        <div class="modal-panel-header">
            <h5 class="modal-panel-title">@(editingRoom == null ? "Add New Room" : "Edit Room")</h5>
            <button class="modal-close-btn" @onclick="CloseModal">&#x2715;</button>
        </div>

        <div class="modal-panel-body">
            <div class="form-row">
                <div class="form-group">
                    <label>Room Number <span class="req">*</span></label>
                    <input class="form-input" @bind="form.RoomNumber" placeholder="e.g. 101" maxlength="10" />
                </div>
                <div class="form-group">
                    <label>Room Type <span class="req">*</span></label>
                    <select class="form-input" @bind="form.RoomType">
                        <option value="">Select type...</option>
                        <option>Standard</option>
                        <option>Deluxe</option>
                    </select>
                </div>
            </div>

            <div class="form-group">
                <label>Description</label>
                <textarea class="form-input" @bind="form.Description" rows="3"
                          placeholder="Brief room description for guests..." maxlength="500"></textarea>
            </div>

            <div class="form-row">
                <div class="form-group">
                    <label>Capacity <span class="req">*</span></label>
                    <input class="form-input" type="number" min="1" max="20" @bind="form.Capacity" />
                </div>
                <div class="form-group">
                    <label>Price per Night (RON) <span class="req">*</span></label>
                    <input class="form-input" type="number" min="0" step="0.01" @bind="form.PricePerNight" />
                </div>
            </div>

            @if (editingRoom != null)
            {
                <div class="form-group">
                    <label>Availability</label>
                    <div class="toggle-row">
                        <input type="checkbox" id="availCheck" @bind="form.IsAvailable" class="form-check-input me-2" />
                        <label for="availCheck">Room is available for booking</label>
                    </div>
                </div>
            }

            <div class="form-group">
                <label>Room Photo</label>
                @if (!string.IsNullOrEmpty(form.PhotoPath))
                {
                    <div class="photo-preview-wrap">
                        <img src="@form.PhotoPath" alt="Preview" class="photo-preview" />
                        <button type="button" class="remove-photo-btn" @onclick="RemovePhoto">Remove photo</button>
                    </div>
                }
                <InputFile OnChange="OnPhotoSelected" accept="image/jpeg,image/png,image/webp" class="file-input" />
                <p class="file-hint">JPEG, PNG or WebP — max 5 MB</p>
                @if (uploadError is not null)
                {
                    <p class="text-danger small">@uploadError</p>
                }
            </div>
        </div>

        <div class="modal-panel-footer">
            <button class="btn-admin-secondary" @onclick="CloseModal" disabled="@saving">Cancel</button>
            <button class="btn-admin-primary" @onclick="SaveRoom" disabled="@saving">
                @if (saving)
                {
                    <span class="spinner-border spinner-border-sm me-1"></span>
                }
                @(editingRoom == null ? "Create Room" : "Save Changes")
            </button>
        </div>
    </div>
}

@* Delete confirmation *@
@if (deletingRoom != null)
{
    <div class="modal-backdrop" @onclick="() => deletingRoom = null"></div>
    <div class="confirm-dialog" @onclick:stopPropagation="true">
        <div style="font-size:2rem; text-align:center; margin-bottom:8px">&#x26A0;&#xFE0F;</div>
        <h5 class="text-center">Delete Room @deletingRoom.RoomNumber?</h5>
        <p class="text-muted text-center small">This action cannot be undone.</p>
        <div class="d-flex gap-2 mt-3">
            <button class="btn-admin-secondary flex-fill" @onclick="() => deletingRoom = null">Cancel</button>
            <button class="btn-danger-full flex-fill" @onclick="DeleteRoom">Delete</button>
        </div>
    </div>
}

