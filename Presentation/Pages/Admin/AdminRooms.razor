@code {
    private List<Room> rooms = [];
    private readonly Dictionary<string, string> userEmails = new();
    private bool initialized = false;
    private bool showModal = false;
    private bool saving = false;
    private Room? editingRoom;
    private Room? deletingRoom;
    private string? successMessage;
    private string? errorMessage;
    private string? uploadError;

    private RoomForm form = new();

    protected override async Task OnInitializedAsync()
    {
        var authState = await Auth.GetAuthenticationStateAsync();
        var user = await UserManager.GetUserAsync(authState.User);

        if (user?.IsAdmin != true)
        {
            Nav.NavigateTo("/");
            return;
        }

        await LoadRooms();
        initialized = true;
    }

    private async Task LoadRooms()
    {
        rooms = await Mediator.Send(new GetAllRoomsQuery());

        userEmails.Clear();
        var ids = rooms
            .Where(r => !string.IsNullOrEmpty(r.ReservedByUserId))
            .Select(r => r.ReservedByUserId!)
            .Distinct();

        foreach (var id in ids)
        {
            var u = await UserManager.FindByIdAsync(id);
            if (u?.Email is not null) userEmails[id] = u.Email;
        }
    }

    private void OpenAddModal()
    {
        editingRoom = null;
        form = new RoomForm { IsAvailable = true };
        uploadError = null;
        showModal = true;
    }

    private void OpenEditModal(Room room)
    {
        editingRoom = room;
        form = new RoomForm
        {
            RoomNumber = room.RoomNumber,
            RoomType = room.RoomType,
            Description = room.Description,
            PricePerNight = room.PricePerNight,
            Capacity = room.Capacity,
            IsAvailable = room.IsAvailable,
            PhotoPath = room.PhotoPath
        };
        uploadError = null;
        showModal = true;
    }

    private void CloseModal()
    {
        showModal = false;
        editingRoom = null;
    }

    private async Task OnPhotoSelected(InputFileChangeEventArgs e)
    {
        uploadError = null;
        var file = e.File;

        if (file.Size > 5 * 1024 * 1024)
        {
            uploadError = "File is too large. Maximum size is 5 MB.";
            return;
        }

        var allowed = new[] { "image/jpeg", "image/png", "image/webp" };
        if (!allowed.Contains(file.ContentType))
        {
            uploadError = "Only JPEG, PNG and WebP images are allowed.";
            return;
        }

        var ext = Path.GetExtension(file.Name).ToLowerInvariant();
        var fileName = $"{Guid.NewGuid()}{ext}";
        var folder = Path.Combine(WebHostEnv.WebRootPath, "images", "rooms");
        Directory.CreateDirectory(folder);
        var fullPath = Path.Combine(folder, fileName);

        await using var readStream = file.OpenReadStream(maxAllowedSize: 5 * 1024 * 1024);
        await using var writeStream = File.Create(fullPath);
        await readStream.CopyToAsync(writeStream);

        form.PhotoPath = $"/images/rooms/{fileName}";
    }

    private void RemovePhoto() => form.PhotoPath = null;

    private async Task SaveRoom()
    {
        if (string.IsNullOrWhiteSpace(form.RoomNumber) || string.IsNullOrWhiteSpace(form.RoomType) || form.Capacity < 1)
        {
            errorMessage = "Room Number, Type and Capacity are required.";
            return;
        }

        saving = true;
        errorMessage = null;

        try
        {
            if (editingRoom == null)
            {
                await Mediator.Send(new CreateRoomCommand(
                    form.RoomNumber.Trim(),
                    form.RoomType,
                    form.Description?.Trim() ?? "",
                    form.PricePerNight,
                    form.Capacity,
                    form.PhotoPath));

                successMessage = $"Room {form.RoomNumber} created successfully.";
            }
            else
            {
                await Mediator.Send(new UpdateRoomCommand(
                    editingRoom.Id,
                    form.RoomNumber.Trim(),
                    form.RoomType,
                    form.Description?.Trim() ?? "",
                    form.PricePerNight,
                    form.Capacity,
                    form.IsAvailable,
                    form.PhotoPath));

                successMessage = $"Room {form.RoomNumber} updated successfully.";
            }

            showModal = false;
            await LoadRooms();
        }
        catch (Exception ex)
        {
            errorMessage = $"Error saving room: {ex.Message}";
        }
        finally
        {
            saving = false;
        }
    }

    private void ConfirmDelete(Room room) => deletingRoom = room;

    private async Task DeleteRoom()
    {
        if (deletingRoom is null) return;

        await Mediator.Send(new DeleteRoomCommand(deletingRoom.Id));
        successMessage = $"Room {deletingRoom.RoomNumber} deleted.";
        deletingRoom = null;
        await LoadRooms();
    }

    private class RoomForm
    {
        public string RoomNumber { get; set; } = "";
        public string RoomType { get; set; } = "";
        public string Description { get; set; } = "";
        public decimal PricePerNight { get; set; }
        public int Capacity { get; set; } = 1;
        public bool IsAvailable { get; set; } = true;
        public string? PhotoPath { get; set; }
    }
}
