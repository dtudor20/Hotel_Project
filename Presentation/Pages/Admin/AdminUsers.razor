@page "/admin/users"
@rendermode RenderMode.InteractiveServer
@layout AdminLayout
@attribute [Authorize]
@using Hotel.Application.Requests.Commands
@using Hotel.Application.Requests.Queries
@using Hotel.Domain.Entities
@using MediatR
@using Microsoft.AspNetCore.Identity
@inject IMediator Mediator
@inject UserManager<ApplicationUser> UserManager
@inject AuthenticationStateProvider Auth
@inject NavigationManager Nav

<PageTitle>Users - Hotel Admin</PageTitle>

@if (!initialized)
{
    <div class="d-flex align-items-center gap-3">
        <div class="spinner-border text-primary" role="status"></div>
        <span class="text-muted">Loading users...</span>
    </div>
}
else
{
    <div class="page-header mb-4">
        <div>
            <h2 class="page-h2">User Management</h2>
            <p class="text-muted mb-0">View and manage all registered accounts.</p>
        </div>
        <div class="user-count-badge">
            @users.Count @(users.Count == 1 ? "user" : "users")
        </div>
    </div>

    @if (!string.IsNullOrEmpty(statusMessage))
    {
        <div class="alert @(isError ? "alert-danger" : "alert-success") alert-dismissible mb-4" role="alert">
            @statusMessage
            <button type="button" class="btn-close" @onclick="() => statusMessage = null"></button>
        </div>
    }

    <div class="admin-card">
        @if (users.Count == 0)
        {
            <div class="empty-table-state">
                <div style="font-size:2.5rem">&#x1F465;</div>
                <p class="mt-2 text-muted">No users registered yet.</p>
            </div>
        }
        else
        {
            <div class="users-search mb-3">
                <input class="search-input" type="text" placeholder="&#x1F50D; Search by email..."
                       @bind="searchTerm" @bind:event="oninput" />
            </div>

            <div class="table-responsive">
                <table class="admin-table">
                    <thead>
                        <tr>
                            <th>Email</th>
                            <th>Role</th>
                            <th>Email Confirmed</th>
                            <th>Status</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var user in FilteredUsers)
                        {
                            var isLocked = user.LockoutEnd.HasValue && user.LockoutEnd > DateTimeOffset.UtcNow;

                            <tr class="@(user.Id == currentUserId ? "current-user-row" : "")">
                                <td>
                                    <div class="user-cell">
                                        <div class="user-avatar-sm">@GetInitials(user.Email)</div>
                                        <div>
                                            <div class="user-email">@user.Email</div>
                                            @if (user.Id == currentUserId)
                                            {
                                                <div class="you-tag">You</div>
                                            }
                                        </div>
                                    </div>
                                </td>
                                <td>
                                    @if (user.IsAdmin)
                                    {
                                        <span class="role-badge role-admin">&#x1F6E1; Admin</span>
                                    }
                                    else
                                    {
                                        <span class="role-badge role-user">&#x1F464; User</span>
                                    }
                                </td>
                                <td>
                                    @if (user.EmailConfirmed)
                                    {
                                        <span class="text-success">&#x2713; Confirmed</span>
                                    }
                                    else
                                    {
                                        <span class="text-muted">&#x2717; Pending</span>
                                    }
                                </td>
                                <td>
                                    <span class="status-pill @(isLocked ? "pill-unavailable" : "pill-available")">
                                        @(isLocked ? "Suspended" : "Active")
                                    </span>
                                </td>
                                <td>
                                    @if (user.Id != currentUserId)
                                    {
                                        <button class="btn-action @(isLocked ? "btn-activate" : "btn-suspend")"
                                                @onclick="() => ToggleUser(user)">
                                            @(isLocked ? "&#x25B6; Activate" : "&#x23F8; Suspend")
                                        </button>
                                    }
                                    else
                                    {
                                        <span class="text-muted small">—</span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            @if (FilteredUsers.Count == 0 && !string.IsNullOrEmpty(searchTerm))
            {
                <p class="text-muted text-center py-3 small">No users match "<strong>@searchTerm</strong>"</p>
            }
        }
    </div>
}

<style>
    .page-header {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
    }

    .page-h2 {
        font-family: Georgia, serif;
        font-size: 1.5rem;
        font-weight: 500;
        color: #F5EBC7;
        margin-bottom: 4px;
        letter-spacing: 0.02em;
    }

    .user-count-badge {
        background: rgba(217,185,95,0.12);
        color: #D9B95F;
        padding: 8px 20px;
        border-radius: 22px;
        font-size: 0.78rem;
        font-weight: 700;
        letter-spacing: 0.10em;
        text-transform: uppercase;
        border: 1px solid rgba(217,185,95,0.30);
    }

    .users-search { max-width: 340px; }

    .search-input {
        width: 100%;
        padding: 10px 14px;
        border: 1px solid #2A2010;
        border-radius: 22px;
        font-size: 0.9rem;
        outline: none;
        background: #0E0C08;
        color: #F5EBC7;
        transition: border-color 0.18s, box-shadow 0.18s;
    }

    .search-input::placeholder { color: #6F6657; }

    .search-input:focus {
        border-color: #D9B95F;
        background: #14110B;
        box-shadow: 0 0 0 3px rgba(217,185,95,0.15);
    }

    .empty-table-state { text-align: center; padding: 60px 24px; color: #B8A878; }

    .admin-table {
        width: 100%;
        border-collapse: collapse;
        font-size: 0.88rem;
        color: #F5EBC7;
    }

    .admin-table th {
        background: rgba(217,185,95,0.06);
        color: #B8A878;
        font-weight: 600;
        font-size: 0.7rem;
        text-transform: uppercase;
        letter-spacing: 0.10em;
        padding: 13px 14px;
        border-bottom: 1px solid #2A2010;
        white-space: nowrap;
    }

    .admin-table td {
        padding: 14px 14px;
        border-bottom: 1px solid #2A2010;
        color: #F5EBC7;
        vertical-align: middle;
    }

    .admin-table tr:last-child td { border-bottom: none; }
    .admin-table tr:hover td { background: rgba(217,185,95,0.04); }
    .current-user-row td { background: rgba(217,185,95,0.07) !important; }

    .user-cell { display: flex; align-items: center; gap: 12px; }

    .user-avatar-sm {
        width: 36px;
        height: 36px;
        border-radius: 50%;
        background: linear-gradient(135deg, #D9B95F, #B8943D);
        color: #14110B;
        font-weight: 700;
        font-size: 0.78rem;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
    }

    .user-email { font-size: 0.9rem; color: #F5EBC7; font-weight: 500; }
    .you-tag {
        font-size: 0.65rem;
        color: #D9B95F;
        font-weight: 700;
        background: rgba(217,185,95,0.10);
        padding: 1px 8px;
        border-radius: 8px;
        display: inline-block;
        margin-top: 3px;
        letter-spacing: 0.10em;
        text-transform: uppercase;
        border: 1px solid rgba(217,185,95,0.30);
    }

    .role-badge {
        font-size: 0.7rem;
        font-weight: 700;
        padding: 4px 12px;
        border-radius: 12px;
        display: inline-block;
        letter-spacing: 0.08em;
        text-transform: uppercase;
    }

    .role-admin { background: rgba(217,185,95,0.14); color: #D9B95F; border: 1px solid rgba(217,185,95,0.30); }
    .role-user  { background: rgba(245,235,199,0.06); color: #B8A878; border: 1px solid #2A2010; }

    .status-pill {
        display: inline-block;
        padding: 4px 12px;
        border-radius: 20px;
        font-size: 0.7rem;
        font-weight: 700;
        letter-spacing: 0.08em;
        text-transform: uppercase;
    }

    .pill-available   { background: rgba(122,176,122,0.18); color: #9CC79C; border: 1px solid rgba(122,176,122,0.40); }
    .pill-unavailable { background: rgba(180,90,90,0.18);   color: #E1A0A0; border: 1px solid rgba(180,90,90,0.40); }

    .btn-action {
        padding: 6px 14px;
        border-radius: 16px;
        font-size: 0.72rem;
        font-weight: 600;
        letter-spacing: 0.06em;
        text-transform: uppercase;
        border: 1px solid transparent;
        cursor: pointer;
        transition: all 0.18s;
    }

    .btn-activate {
        background: rgba(122,176,122,0.12);
        color: #9CC79C;
        border-color: rgba(122,176,122,0.40);
    }
    .btn-activate:hover { background: rgba(122,176,122,0.22); border-color: #9CC79C; }

    .btn-suspend {
        background: rgba(226,193,90,0.10);
        color: #E2C15A;
        border-color: rgba(226,193,90,0.30);
    }
    .btn-suspend:hover { background: rgba(226,193,90,0.20); border-color: #E2C15A; }

    .text-success { color: #9CC79C !important; }
</style>

@code {
    private List<ApplicationUser> users = [];
    private bool initialized = false;
    private string searchTerm = "";
    private string? currentUserId;
    private string? statusMessage;
    private bool isError = false;

    private List<ApplicationUser> FilteredUsers =>
        string.IsNullOrWhiteSpace(searchTerm)
            ? users
            : users.Where(u => u.Email?.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) == true).ToList();

    protected override async Task OnInitializedAsync()
    {
        var authState = await Auth.GetAuthenticationStateAsync();
        var currentUser = await UserManager.GetUserAsync(authState.User);

        if (currentUser?.IsAdmin != true)
        {
            Nav.NavigateTo("/");
            return;
        }

        currentUserId = currentUser.Id;
        await LoadUsers();
        initialized = true;
    }

    private async Task LoadUsers()
    {
        users = await Mediator.Send(new GetAllUsersQuery());
    }

    private async Task ToggleUser(ApplicationUser user)
    {
        isError = false;
        var success = await Mediator.Send(new ToggleUserActiveCommand(user.Id));

        if (success)
        {
            var isLocked = user.LockoutEnd.HasValue && user.LockoutEnd > DateTimeOffset.UtcNow;
            statusMessage = isLocked
                ? $"User {user.Email} has been activated."
                : $"User {user.Email} has been suspended.";

            await LoadUsers();
        }
        else
        {
            isError = true;
            statusMessage = "Failed to update user status.";
        }
    }

    private static string GetInitials(string? email)
    {
        if (string.IsNullOrWhiteSpace(email)) return "?";
        return char.ToUpper(email[0]).ToString();
    }
}
