@using Hotel.Domain.Entities

<nav class="navbar navbar-expand-lg navbar-light bg-white shadow-sm">
    <div class="container">
        <a class="navbar-brand fw-semibold" href="/">
            &#x1F3E8; Hotel
        </a>

        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarMain">
            <span class="navbar-toggler-icon"></span>
        </button>

        <div class="collapse navbar-collapse" id="navbarMain">
            <ul class="navbar-nav me-auto ms-3">
                <li class="nav-item">
                    <a class="nav-link" href="/">Home</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" href="/rooms">Rooms</a>
                </li>
            </ul>

            <AuthorizeView>
                <Authorized>
                    <div class="d-flex align-items-center gap-3">
                        @if (context.User.HasClaim("IsAdmin", "true"))
                        {
                            <a class="btn btn-outline-primary btn-sm px-3" href="/admin">Admin Panel</a>
                        }
                        <span class="text-muted small">@context.User.Identity?.Name</span>
                        <form method="post" action="/account/logout" class="m-0">
                            <AntiforgeryToken />
                            <input type="hidden" name="ReturnUrl" value="/" />
                            <button class="btn btn-outline-secondary btn-sm px-3" type="submit">Logout</button>
                        </form>
                    </div>
                </Authorized>
                <NotAuthorized>
                    <div class="d-flex gap-2">
                        <a class="btn btn-outline-secondary px-4" href="/register">Register</a>
                        <a class="btn btn-primary px-4" href="/login">Login</a>
                    </div>
                </NotAuthorized>
            </AuthorizeView>
        </div>
    </div>
</nav>
