@using Hotel.Domain.Entities

<nav class="aurum-nav">
    <div class="aurum-nav-inner">
        <a class="aurum-brand" href="/">
            <span class="brand-mark">A</span>
            <div class="brand-text">
                <span class="brand-name">AurumStay</span>
                <span class="brand-tag">Hotel &amp; Residences</span>
            </div>
        </a>

        <button class="aurum-nav-toggler" type="button" onclick="document.getElementById('aurumNavLinks').classList.toggle('open')">
            <span></span><span></span><span></span>
        </button>

        <div class="aurum-nav-links" id="aurumNavLinks">
            <a class="aurum-link" href="/">Home</a>
            <a class="aurum-link" href="/rooms">Rooms</a>

            <AuthorizeView>
                <Authorized>
                    @if (context.User.HasClaim("IsAdmin", "true"))
                    {
                        <a class="aurum-btn-ghost" href="/admin">Operations</a>
                    }
                    <span class="aurum-user">@context.User.Identity?.Name</span>
                    <form method="post" action="/account/logout" class="aurum-form">
                        <AntiforgeryToken />
                        <input type="hidden" name="ReturnUrl" value="/" />
                        <button class="aurum-btn-ghost" type="submit">Sign out</button>
                    </form>
                </Authorized>
                <NotAuthorized>
                    <a class="aurum-btn-ghost" href="/register">Register</a>
                    <a class="aurum-btn-primary" href="/login">Sign in</a>
                </NotAuthorized>
            </AuthorizeView>
        </div>
    </div>
</nav>

<style>
    .aurum-nav {
        position: sticky;
        top: 0;
        z-index: 50;
        background: rgba(247,241,230,0.92);
        backdrop-filter: blur(10px);
        border-bottom: 1px solid #E7DCC5;
    }

    .aurum-nav-inner {
        max-width: 1240px;
        margin: 0 auto;
        padding: 14px 28px;
        display: flex;
        align-items: center;
        gap: 24px;
    }

    .aurum-brand {
        display: flex;
        align-items: center;
        gap: 12px;
        text-decoration: none;
        color: #14110B;
    }

    .aurum-brand:hover { text-decoration: none; color: #14110B; }

    .brand-mark {
        width: 38px;
        height: 38px;
        border-radius: 50%;
        background: linear-gradient(135deg, #D9B95F, #B8943D);
        color: #14110B;
        font-family: Georgia, serif;
        font-weight: 700;
        font-size: 1.2rem;
        display: flex;
        align-items: center;
        justify-content: center;
        box-shadow: 0 4px 14px rgba(217,185,95,0.35);
    }

    .brand-text { display: flex; flex-direction: column; line-height: 1.1; }

    .brand-name {
        font-family: Georgia, serif;
        font-size: 1.15rem;
        font-weight: 600;
        letter-spacing: 0.04em;
        color: #14110B;
    }

    .brand-tag {
        font-size: 0.65rem;
        letter-spacing: 0.18em;
        text-transform: uppercase;
        color: #9C8E72;
        margin-top: 2px;
    }

    .aurum-nav-links {
        margin-left: auto;
        display: flex;
        align-items: center;
        gap: 18px;
    }

    .aurum-link {
        font-size: 0.88rem;
        letter-spacing: 0.06em;
        color: #14110B;
        text-decoration: none;
        padding: 6px 2px;
        border-bottom: 1px solid transparent;
        transition: border-color 0.18s, color 0.18s;
    }

    .aurum-link:hover {
        color: #B8943D;
        text-decoration: none;
        border-bottom-color: #D9B95F;
    }

    .aurum-user {
        font-size: 0.82rem;
        color: #6F6657;
        font-style: italic;
    }

    .aurum-form { margin: 0; padding: 0; }

    .aurum-btn-ghost {
        background: transparent;
        color: #14110B;
        border: 1px solid #B8943D;
        padding: 7px 18px;
        border-radius: 22px;
        font-size: 0.8rem;
        font-weight: 600;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        text-decoration: none;
        cursor: pointer;
        transition: all 0.2s ease;
        display: inline-block;
    }

    .aurum-btn-ghost:hover {
        background: #14110B;
        color: #F5EBC7;
        border-color: #14110B;
        text-decoration: none;
    }

    .aurum-btn-primary {
        background: #14110B;
        color: #F5EBC7;
        border: 1px solid #14110B;
        padding: 7px 22px;
        border-radius: 22px;
        font-size: 0.8rem;
        font-weight: 600;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        text-decoration: none;
        cursor: pointer;
        transition: all 0.2s ease;
        display: inline-block;
    }

    .aurum-btn-primary:hover {
        background: #D9B95F;
        color: #14110B;
        border-color: #D9B95F;
        text-decoration: none;
    }

    .aurum-nav-toggler {
        display: none;
        background: transparent;
        border: 0;
        flex-direction: column;
        gap: 4px;
        cursor: pointer;
        padding: 6px;
        margin-left: auto;
    }

    .aurum-nav-toggler span {
        width: 22px;
        height: 2px;
        background: #14110B;
        border-radius: 2px;
    }

    @@media (max-width: 820px) {
        .aurum-nav-toggler { display: flex; }
        .aurum-nav-links {
            position: absolute;
            top: 100%;
            left: 0;
            right: 0;
            margin-left: 0;
            background: #F7F1E6;
            border-bottom: 1px solid #E7DCC5;
            flex-direction: column;
            align-items: stretch;
            gap: 8px;
            padding: 16px 24px 22px;
            display: none;
        }
        .aurum-nav-links.open { display: flex; }
        .aurum-link { padding: 8px 0; }
    }
</style>
