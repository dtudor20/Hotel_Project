@inherits LayoutComponentBase
@inject NavigationManager Nav

<div class="admin-shell">
    <aside class="admin-sidebar">
        <div class="sidebar-brand">
            <span class="brand-mark">A</span>
            <div>
                <div class="brand-name">AurumStay</div>
                <div class="brand-sub">Operations</div>
            </div>
        </div>

        <nav class="sidebar-nav">
            <div class="nav-section-label">Overview</div>
            <a class="sidebar-link @ActiveClass("/admin", exact: true)" href="/admin">
                <span class="nav-icon">&#x25CB;</span>
                Dashboard
            </a>

            <div class="nav-section-label">Management</div>
            <a class="sidebar-link @ActiveClass("/admin/rooms")" href="/admin/rooms">
                <span class="nav-icon">&#x25A1;</span>
                Rooms
            </a>
            <a class="sidebar-link @ActiveClass("/admin/users")" href="/admin/users">
                <span class="nav-icon">&#x25C7;</span>
                Users
            </a>
        </nav>

        <div class="sidebar-bottom">
            <a class="sidebar-link sidebar-link-muted" href="/" target="_self">
                <span class="nav-icon">&#x2197;</span>
                View public site
            </a>
            <form method="post" action="/account/logout" class="m-0 mt-1">
                <AntiforgeryToken />
                <input type="hidden" name="ReturnUrl" value="/" />
                <button class="sidebar-logout-btn" type="submit">
                    <span class="nav-icon">&#x23FB;</span>
                    Sign out
                </button>
            </form>
        </div>
    </aside>

    <div class="admin-content-area">
        <header class="admin-topbar">
            <div class="topbar-breadcrumb">
                <span class="breadcrumb-root">Operations</span>
                <span class="breadcrumb-sep">/</span>
                <span class="breadcrumb-current">@CurrentPageName</span>
            </div>

            <AuthorizeView>
                <Authorized>
                    <div class="topbar-user">
                        <div class="user-avatar">@GetInitials(context.User.Identity?.Name)</div>
                        <div class="user-info">
                            <div class="user-name">@context.User.Identity?.Name</div>
                            <div class="user-role">Administrator</div>
                        </div>
                    </div>
                </Authorized>
            </AuthorizeView>
        </header>

        <main class="admin-main-content">
            @Body
        </main>
    </div>
</div>

<style>
    *, *::before, *::after { box-sizing: border-box; }

    html, body { margin: 0; padding: 0; height: 100%; background: #050505; }

    .admin-shell {
        display: flex;
        min-height: 100vh;
        background: #0E0C08;
        color: #F5EBC7;
        font-family: 'Inter', 'Segoe UI', system-ui, -apple-system, sans-serif;
    }

    /* ── Sidebar ── */
    .admin-sidebar {
        width: 256px;
        min-height: 100vh;
        background: #050505;
        border-right: 1px solid #2A2010;
        display: flex;
        flex-direction: column;
        position: fixed;
        top: 0;
        left: 0;
        z-index: 200;
        overflow-y: auto;
    }

    .sidebar-brand {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 26px 22px 22px;
        border-bottom: 1px solid #2A2010;
    }

    .brand-mark {
        width: 38px;
        height: 38px;
        border-radius: 50%;
        background: linear-gradient(135deg, #D9B95F, #B8943D);
        color: #14110B;
        font-family: Georgia, serif;
        font-weight: 700;
        font-size: 1.2rem;
        display: flex;
        align-items: center;
        justify-content: center;
        box-shadow: 0 4px 14px rgba(217,185,95,0.30);
    }

    .brand-name {
        font-family: Georgia, serif;
        font-size: 1.05rem;
        font-weight: 600;
        color: #F5EBC7;
        line-height: 1.1;
        letter-spacing: 0.03em;
    }

    .brand-sub {
        font-size: 0.65rem;
        color: #B8A878;
        text-transform: uppercase;
        letter-spacing: 0.18em;
        margin-top: 3px;
    }

    .sidebar-nav { flex: 1; padding: 14px 0; }

    .nav-section-label {
        padding: 20px 22px 8px;
        font-size: 0.62rem;
        font-weight: 700;
        letter-spacing: 0.22em;
        color: #6F6657;
        text-transform: uppercase;
    }

    .sidebar-link {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 11px 22px;
        color: #B8A878;
        text-decoration: none !important;
        font-size: 0.88rem;
        font-weight: 500;
        letter-spacing: 0.02em;
        border-left: 2px solid transparent;
        transition: all 0.18s;
        cursor: pointer;
    }

    .sidebar-link:hover {
        background: rgba(217,185,95,0.06);
        color: #F5EBC7;
        text-decoration: none;
    }

    .sidebar-link.active {
        background: rgba(217,185,95,0.10);
        color: #D9B95F;
        border-left-color: #D9B95F;
    }

    .sidebar-link-muted { color: rgba(184,168,120,0.55); }

    .nav-icon { font-size: 0.95rem; flex-shrink: 0; }

    .sidebar-bottom {
        padding: 14px 14px 22px;
        border-top: 1px solid #2A2010;
    }

    .sidebar-logout-btn {
        display: flex;
        align-items: center;
        gap: 11px;
        width: 100%;
        background: transparent;
        border: 1px solid #5A2020;
        color: #d8806b;
        padding: 10px 18px;
        border-radius: 22px;
        font-size: 0.82rem;
        font-weight: 600;
        letter-spacing: 0.06em;
        text-transform: uppercase;
        cursor: pointer;
        transition: all 0.18s;
        margin-top: 6px;
    }

    .sidebar-logout-btn:hover {
        background: #5A2020;
        color: #FFE3DC;
        border-color: #5A2020;
    }

    /* ── Content area ── */
    .admin-content-area {
        margin-left: 256px;
        flex: 1;
        display: flex;
        flex-direction: column;
        min-height: 100vh;
        background: #0E0C08;
    }

    .admin-topbar {
        height: 64px;
        background: #14110B;
        border-bottom: 1px solid #2A2010;
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 0 34px;
        position: sticky;
        top: 0;
        z-index: 100;
    }

    .topbar-breadcrumb {
        display: flex;
        align-items: center;
        gap: 10px;
        font-size: 0.88rem;
    }

    .breadcrumb-root { color: #B8A878; letter-spacing: 0.06em; }
    .breadcrumb-sep  { color: #4A3A17; }
    .breadcrumb-current { color: #F5EBC7; font-weight: 600; }

    .topbar-user {
        display: flex;
        align-items: center;
        gap: 12px;
    }

    .user-avatar {
        width: 36px;
        height: 36px;
        border-radius: 50%;
        background: linear-gradient(135deg, #D9B95F, #B8943D);
        color: #14110B;
        font-weight: 700;
        font-size: 0.8rem;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .user-name { font-size: 0.85rem; font-weight: 600; color: #F5EBC7; line-height: 1.2; }
    .user-role { font-size: 0.7rem; color: #B8A878; letter-spacing: 0.06em; }

    .admin-main-content {
        padding: 36px;
        flex: 1;
        background: #0E0C08;
        color: #F5EBC7;
    }

    /* ── Shared admin card ── */
    .admin-card {
        background: #14110B;
        border: 1px solid #2A2010;
        border-radius: 14px;
        box-shadow: 0 2px 18px rgba(0,0,0,0.30);
        padding: 26px;
    }

    /* Style overrides so Bootstrap-based content reads on dark */
    .admin-main-content .text-muted { color: #B8A878 !important; }
    .admin-main-content .alert-success {
        background: rgba(60,140,90,0.18);
        border-color: rgba(60,140,90,0.45);
        color: #b6e3c6;
    }
    .admin-main-content .alert-danger {
        background: rgba(180,60,60,0.16);
        border-color: rgba(180,60,60,0.45);
        color: #f1b7b0;
    }
    .admin-main-content .btn-close { filter: invert(0.85); }

    @@media (max-width: 900px) {
        .admin-sidebar { width: 210px; }
        .admin-content-area { margin-left: 210px; }
        .admin-main-content { padding: 26px 22px; }
    }
</style>

@code {
    private string CurrentPageName => Nav.Uri switch
    {
        var u when u.Contains("/admin/rooms") => "Rooms",
        var u when u.Contains("/admin/users") => "Users",
        _ => "Dashboard"
    };

    private string ActiveClass(string path, bool exact = false)
    {
        var current = new Uri(Nav.Uri).AbsolutePath.TrimEnd('/');
        var target = path.TrimEnd('/');
        return exact ? (current == target ? "active" : "") : current.StartsWith(target) ? "active" : "";
    }

    private static string GetInitials(string? name)
    {
        if (string.IsNullOrWhiteSpace(name)) return "?";
        var parts = name.Split('@')[0].Split('.');
        return parts.Length >= 2
            ? $"{char.ToUpper(parts[0][0])}{char.ToUpper(parts[1][0])}"
            : char.ToUpper(name[0]).ToString();
    }
}
